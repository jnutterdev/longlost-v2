---
import Page from "../../layouts/Page.astro";
import Rating from "../../components/Rating.astro";
import { getCollection } from "astro:content";

const entries = (await getCollection("books"))
    .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const reading = entries.filter(e => e.data.status === "reading");
const finished = entries.filter(e => e.data.status !== "reading");
---

<Page title="Reading" currentNav="reading">
    <div class="container">
        <div class="archive-header">
            <h1 class="page-title">Reading</h1>
        </div>

        {reading.length > 0 && (
            <section class="book-section">
                <h2 class="section-label">Currently reading</h2>
                <div class="book-list">
                    {reading.map(entry => (
                        <article class="book-entry">
                            <h3 class="book-title">
                                <a href={`/reading/${entry.id}`}>{entry.data.bookTitle}</a>
                            </h3>
                            <p class="book-author">{entry.data.author}</p>
                            {entry.data.rating && <Rating rating={entry.data.rating} icon="fa-dragon" />}
                        </article>
                    ))}
                </div>
            </section>
        )}

        {finished.length > 0 && (
            <section class="book-section">
                <h2 class="section-label">Recently finished</h2>
                <div class="book-list">
                    {finished.map(entry => (
                        <article class="book-entry">
                            <h3 class="book-title">
                                <a href={`/reading/${entry.id}`}>{entry.data.bookTitle}</a>
                            </h3>
                            <p class="book-author">{entry.data.author}</p>
                            {entry.data.rating && <Rating rating={entry.data.rating} icon="fa-dragon" />}
                        </article>
                    ))}
                </div>
            </section>
        )}

        {entries.length === 0 && <p class="empty">Nothing logged yet.</p>}
    </div>
</Page>

<style>
    .archive-header {
        padding-top: var(--space-xl);
        padding-bottom: var(--space-lg);
    }

    .page-title {
        font-family: var(--font-heading);
        font-style: italic;
        font-weight: 700;
        font-size: 3.8rem;
        line-height: 1.05;
        color: var(--text);
    }

    .book-section {
        margin-bottom: var(--space-xl);
    }

    .section-label {
        font-family: var(--font-ui);
        font-size: 0.65rem;
        font-weight: 500;
        letter-spacing: 0.1em;
        text-transform: uppercase;
        color: var(--text-muted);
        margin-bottom: var(--space-md);
    }

    .book-entry {
        padding-block: var(--space-sm);
    }

    .book-entry + .book-entry {
        border-top: 1px solid var(--rule);
    }

    .book-title {
        font-family: var(--font-heading);
        font-style: italic;
        font-weight: 700;
        font-size: 1.2rem;
        line-height: 1.3;
    }

    .book-title a { color: var(--text); text-decoration: none; }
    .book-title a:hover { color: var(--link); text-decoration: none; }

    .book-author {
        font-family: var(--font-ui);
        font-size: 0.78rem;
        color: var(--text-muted);
        margin-top: 0.2em;
    }

    .empty { color: var(--text-muted); font-style: italic; padding-block: var(--space-xl); }
</style>
