---
import Page from "../layouts/Page.astro";
---

<Page title="About" currentNav="about">
    <div class="container">
        <div class="page-header">
            <h1 class="page-title">about</h1>
        </div>

        <div class="about-body">
            <p>
                I'm John. I make music, take photographs, read books, and watch too many films.
                This site is where I keep a record of those things — not for any particular
                audience, but because writing things down makes them feel more real.
            </p>
            <p>
                The name is <em>longlostforgotten</em> — one word. It's a description of
                most of the things I try to hold onto here.
            </p>
            <p>
                The site follows a POSSE model: everything lives here first, and syndicates
                outward from here. The social profiles are distribution channels, not the
                source.
            </p>
        </div>

        <div class="elsewhere">
            <h2 class="elsewhere-heading">Find me elsewhere</h2>
            <ul class="elsewhere-list">
                <li class="elsewhere-item">
                    <a href="https://bsky.app/profile/longlostforgotten.com" target="_blank" rel="noopener">
                        <i class="fa-brands fa-bluesky elsewhere-icon" aria-hidden="true"></i>
                        <span class="elsewhere-platform">Bluesky</span>
                        <span class="elsewhere-handle">longlostforgotten.com</span>
                    </a>
                </li>
                <li class="elsewhere-item">
                    <a href="https://www.instagram.com/lnglostfrgttn/" target="_blank" rel="noopener">
                        <i class="fa-brands fa-instagram elsewhere-icon" aria-hidden="true"></i>
                        <span class="elsewhere-platform">Instagram</span>
                        <span class="elsewhere-handle">@lnglostfrgttn</span>
                    </a>
                </li>
                <li class="elsewhere-item">
                    <a href="https://www.threads.com/@lnglostfrgttn" target="_blank" rel="noopener">
                        <i class="fa-brands fa-threads elsewhere-icon" aria-hidden="true"></i>
                        <span class="elsewhere-platform">Threads</span>
                        <span class="elsewhere-handle">@lnglostfrgttn</span>
                    </a>
                </li>
            </ul>
        </div>
    </div>
</Page>

<style>
    .page-header {
        padding-top: var(--space-xl);
        padding-bottom: var(--space-lg);
    }

    .page-title {
        font-family: var(--font-heading);
        font-style: italic;
        font-weight: 700;
        font-size: 3.8rem;
        line-height: 1.05;
        color: var(--text);
    }

    .about-body {
        max-width: 60ch;
        margin-bottom: var(--space-xl);
    }

    .about-body p {
        font-size: 1rem;
        line-height: 1.85;
        color: var(--text);
        margin-bottom: 1.4em;
    }

    .elsewhere-heading {
        font-family: var(--font-ui);
        font-size: 0.65rem;
        font-weight: 500;
        letter-spacing: 0.1em;
        text-transform: uppercase;
        color: var(--text-muted);
        margin-bottom: var(--space-md);
    }

    .elsewhere-list {
        list-style: none;
        display: flex;
        flex-direction: column;
        gap: var(--space-sm);
        max-width: 420px;
        margin-bottom: var(--space-xl);
    }

    .elsewhere-item a {
        display: flex;
        align-items: center;
        gap: var(--space-md);
        padding: var(--space-sm) var(--space-md);
        border: 1px solid var(--rule);
        border-radius: 3px;
        transition: border-color 0.15s, background-color 0.15s;
        text-decoration: none;
    }

    .elsewhere-item a:hover {
        border-color: var(--link);
        background-color: rgba(196, 169, 122, 0.08);
        text-decoration: none;
    }

    .elsewhere-icon {
        width: 20px;
        font-size: 1.1rem;
        text-align: center;
        color: var(--text-muted);
        flex-shrink: 0;
    }

    .elsewhere-item a:hover .elsewhere-icon {
        color: var(--link);
    }

    .elsewhere-platform {
        font-family: var(--font-ui);
        font-size: 0.8rem;
        font-weight: 500;
        color: var(--text);
        flex: 1;
    }

    .elsewhere-handle {
        font-family: var(--font-ui);
        font-size: 0.72rem;
        color: var(--text-muted);
    }
</style>
