                            <rect x="2" y="2" width="20" height="20" rx="5" ry="5" stroke="currentColor" stroke-width="2" fill="none"/>
                            <circle cx="12" cy="12" r="4" stroke="currentColor" stroke-width="2" fill="none"/>
                            <circle cx="17.5" cy="6.5" r="1" fill="currentColor"/>
                        </svg>
                        <span class="elsewhere-platform">Instagram</span>
                        <span class="elsewhere-handle">@lnglostfrgttn</span>
                    </a>
                </li>
                <li class="elsewhere-item">
                    <a href="https://www.threads.com/@lnglostfrgttn" target="_blank" rel="noopener">
