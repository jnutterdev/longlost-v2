<style>
    .page-header {
        padding-top: var(--space-xl);
        padding-bottom: var(--space-lg);
    }

    .page-title {
        font-family: var(--font-heading);
        font-style: italic;
        font-weight: 700;
        font-size: 3.8rem;
        line-height: 1.05;
        color: var(--text);
    }

    .about-body {
        max-width: 60ch;
        margin-bottom: var(--space-xl);
    }

    .about-body p {
        font-size: 1rem;
        line-height: 1.85;
        color: var(--text);
        margin-bottom: 1.4em;
    }

    .elsewhere-heading {
        font-family: var(--font-ui);
        font-size: 0.65rem;
        font-weight: 500;
        letter-spacing: 0.1em;
        text-transform: uppercase;
        color: var(--text-muted);
        margin-bottom: var(--space-md);
    }

    .elsewhere-list {
        list-style: none;
        display: flex;
        flex-direction: column;
        gap: var(--space-sm);
        max-width: 420px;
        margin-bottom: var(--space-xl);
    }

    .elsewhere-item a {
        display: flex;
        align-items: center;
        gap: var(--space-md);
        padding: var(--space-sm) var(--space-md);
        border: 1px solid var(--rule);
        border-radius: 3px;
        transition: border-color 0.15s, background-color 0.15s;
        text-decoration: none;
    }

    .elsewhere-item a:hover {
        border-color: var(--link);
        background-color: rgba(196, 169, 122, 0.08);
        text-decoration: none;
    }

    .elsewhere-icon {
        width: 20px;
        height: 20px;
        color: var(--text-muted);
        flex-shrink: 0;
    }

    .elsewhere-item a:hover .elsewhere-icon {
        color: var(--link);
    }

    .elsewhere-platform {
        font-family: var(--font-ui);
        font-size: 0.8rem;
        font-weight: 500;
        color: var(--text);
        flex: 1;
    }

    .elsewhere-handle {
        font-family: var(--font-ui);
        font-size: 0.72rem;
        color: var(--text-muted);
    }
</style>
