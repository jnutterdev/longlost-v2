---
import Page from "../layouts/Page.astro";
---

<Page title="About" currentNav="about">
    <div class="container">
        <div class="page-header">
            <h1 class="page-title">about</h1>
        </div>

        <div class="about-body">
            <p>
                I'm John. I make music, take photographs, read books, and watch too many films.
                This site is where I keep a record of those things — not for any particular
                audience, but because writing things down makes them feel more real.
            </p>
            <p>
                The name is <em>longlostforgotten</em> — one word. It's a description of
                most of the things I try to hold onto here.
            </p>
            <p>
                The site follows a POSSE model: everything lives here first, and syndicates
                outward from here. The social profiles are distribution channels, not the
                source.
            </p>
        </div>

        <div class="elsewhere">
            <h2 class="elsewhere-heading">Find me elsewhere</h2>
            <ul class="elsewhere-list">
                <li class="elsewhere-item">
                    <a href="https://bsky.app/profile/longlostforgotten.com" target="_blank" rel="noopener">
