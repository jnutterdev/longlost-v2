---
import Page from "../../layouts/Page.astro";
import Rating from "../../components/Rating.astro";
import { getCollection, render } from "astro:content";

export async function getStaticPaths() {
    const entries = await getCollection("music");
    return entries.map(entry => ({
        params: { slug: entry.id },
        props: { entry },
    }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);

const dateFormatter = new Intl.DateTimeFormat("en-US", {
    year: "numeric", month: "long", day: "numeric",
});

// Build the correct embed src from the embedUrl
const { embedUrl, bandcampAlbumId, platform, alternatePlatformUrl } = entry.data;
const alternatePlatformLabel = platform === "soundcloud" ? "Bandcamp" : "SoundCloud";

const bandcampEmbedSrc = bandcampAlbumId
    ? `https://bandcamp.com/EmbeddedPlayer/album=${bandcampAlbumId}/size=large/bgcol=333333/linkcol=9a64ff/tracklist=false/artwork=small/transparent=true/`
    : null;
const iframeSrc = platform === "bandcamp" && bandcampEmbedSrc ? bandcampEmbedSrc : embedUrl;
---

<Page title={entry.data.title} currentNav="music">
    <div class="container">
        <div class="post-header">
            <div class="post-meta">
                <span class="type-pill music">Music</span>
                <span class="post-date">{dateFormatter.format(entry.data.date)}</span>
            </div>
            <h1 class="post-title">{entry.data.title}</h1>
            {entry.data.rating && <Rating rating={entry.data.rating} />}
        </div>

        <!-- Embed -->
        <div class="music-embed">
            {platform && (
                <p class="embed-label">{platform.charAt(0).toUpperCase() + platform.slice(1)}</p>
            )}
            <iframe
                class:list={["embed-iframe", platform === "bandcamp" && "embed-iframe--bandcamp"]}
                src={iframeSrc}
                scrolling="no"
                frameborder="no"
                allow="autoplay"
                title={entry.data.title}
            ></iframe>
            {alternatePlatformUrl && (
                <p class="embed-also">
                    Also on <a href={alternatePlatformUrl} target="_blank" rel="noopener">{alternatePlatformLabel}</a>
                </p>
            )}
        </div>

        <!-- Notes -->
        <div class="post-body">
            <Content />

            {entry.data.tags.length > 0 && (
                <div class="post-tags">
                    {entry.data.tags.map(tag => (
                        <a href={`/music/tags/${tag}`} class="tag">{tag}</a>
                    ))}
                </div>
            )}
        </div>
    </div>
</Page>

<style>
    .post-header {
        padding-top: var(--space-xl);
        padding-bottom: var(--space-lg);
    }

    .post-meta {
        display: flex;
        align-items: center;
        gap: var(--space-sm);
        margin-bottom: var(--space-md);
    }

    .post-date {
        font-family: var(--font-ui);
        font-size: 0.68rem;
        letter-spacing: 0.06em;
        text-transform: uppercase;
        color: var(--text-muted);
    }

    .post-title {
        font-family: var(--font-heading);
        font-style: italic;
        font-weight: 700;
        font-size: 2.6rem;
        line-height: 1.15;
        color: var(--text);
        letter-spacing: 0.01em;
        max-width: 22ch;
    }

    .music-embed {
        margin-block: var(--space-xl);
    }

    .embed-label {
        font-family: var(--font-ui);
        font-size: 0.62rem;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        color: var(--text-muted);
        margin-bottom: var(--space-sm);
    }

    .embed-iframe {
        width: 100%;
        height: 166px;
        border: none;
        border-radius: 3px;
        display: block;
    }

    .embed-iframe--bandcamp {
        height: 120px;
    }

    .embed-also {
        margin-top: var(--space-sm);
        font-family: var(--font-ui);
        font-size: 0.7rem;
        color: var(--text-muted);
    }

    .post-body {
        padding-bottom: var(--space-xl);
    }

    .post-body :global(p) {
        font-size: 1rem;
        line-height: 1.85;
        color: var(--text);
        margin-bottom: 1.6em;
        max-width: 65ch;
    }

    .post-tags {
        display: flex;
        flex-wrap: wrap;
        gap: var(--space-sm);
        padding-top: var(--space-lg);
        margin-top: var(--space-lg);
        border-top: 1px solid var(--rule);
    }

    @media (max-width: 600px) {
        .post-title { font-size: 2rem; }
    }
</style>
